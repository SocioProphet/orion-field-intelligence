@prefix ofif: <https://socioprophet.org/ofif/ontology/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

ofif:assets a owl:Ontology ; rdfs:label "OFIF Assets Module" .
ofif:Asset a owl:Class ; rdfs:label "Asset" .
ofif:SensorNode a owl:Class ; rdfs:subClassOf ofif:Asset ; rdfs:label "Sensor Node" .
ofif:Gateway a owl:Class ; rdfs:subClassOf ofif:Asset ; rdfs:label "Gateway / Relay" .
ofif:ComputeNode a owl:Class ; rdfs:subClassOf ofif:Asset ; rdfs:label "Compute Node" .
ofif:MobileDevice a owl:Class ; rdfs:subClassOf ofif:Asset ; rdfs:label "Mobile Device" .
ofif:Wearable a owl:Class ; rdfs:subClassOf ofif:Asset ; rdfs:label "Wearable" .
ofif:Vehicle a owl:Class ; rdfs:subClassOf ofif:Asset ; rdfs:label "Vehicle" .
ofif:Drone a owl:Class ; rdfs:subClassOf ofif:Asset ; rdfs:label "Drone / UAS" .
