{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/orion/schemas/orion-fusion-link.v0_1.schema.json",
  "title": "OrionFusionLink v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fusion_link_id",
    "fused_event_ref",
    "input_event_refs",
    "source_record_refs",
    "fusion_method",
    "confidence",
    "rationale"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0" },
    "fusion_link_id": { "type": "string", "pattern": "^orion-fuse-[a-z0-9][a-z0-9._-]*$" },
    "fused_event_ref": { "type": "string", "pattern": "^orion-evt-[a-z0-9][a-z0-9._-]*$" },
    "input_event_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^orion-evt-[a-z0-9][a-z0-9._-]*$" },
      "minItems": 2,
      "uniqueItems": true
    },
    "source_record_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^gaia-src-[a-z0-9][a-z0-9._-]*$" },
      "minItems": 1,
      "uniqueItems": true
    },
    "fusion_method": {
      "type": "string",
      "enum": [
        "fixture.synthetic_rule",
        "geospatial_temporal_correlation",
        "asset_event_correlation",
        "operator_confirmed_correlation",
        "model_inferred",
        "unknown"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rationale": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "notes": { "type": "string" }
  }
}
