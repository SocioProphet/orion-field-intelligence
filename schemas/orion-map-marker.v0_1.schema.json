{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/orion/schemas/orion-map-marker.v0_1.schema.json",
  "title": "OrionMapMarker v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "marker_id",
    "event_ref",
    "layer_group",
    "coordinates",
    "title",
    "severity",
    "confidence",
    "evidence_grade",
    "policy_state",
    "source_count",
    "selectable",
    "action_enabled"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0" },
    "marker_id": { "type": "string", "pattern": "^orion-marker-[a-z0-9][a-z0-9._-]*$" },
    "event_ref": { "type": "string", "pattern": "^orion-evt-[a-z0-9][a-z0-9._-]*$" },
    "layer_group": {
      "type": "string",
      "enum": ["natural_hazard", "facility_asset", "cyber_exposure", "field_report", "fused_incident", "gated_disabled", "unknown"]
    },
    "coordinates": {
      "type": "array",
      "prefixItems": [
        { "type": "number", "minimum": -180, "maximum": 180 },
        { "type": "number", "minimum": -90, "maximum": 90 }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "title": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_grade": {
      "type": "string",
      "enum": ["fixture.synthetic", "public_source.unverified", "public_source.versioned", "public_source.attributed", "operator_report.unverified", "fused.inferred", "policy_gated.action"]
    },
    "policy_state": {
      "type": "string",
      "enum": ["public_view_allowed", "internal_view_allowed", "unverified_source", "attribution_required", "action_gated", "scope_required", "authorization_required", "expired"]
    },
    "source_count": { "type": "integer", "minimum": 1 },
    "asset_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "decision_card_ref": { "type": "string", "pattern": "^orion-card-[a-z0-9][a-z0-9._-]*$" },
    "receipt_ref": { "type": "string", "pattern": "^orion-rcpt-[a-z0-9][a-z0-9._-]*$" },
    "selectable": { "type": "boolean" },
    "action_enabled": { "type": "boolean" },
    "action_disabled_reason": { "type": "string" }
  }
}
