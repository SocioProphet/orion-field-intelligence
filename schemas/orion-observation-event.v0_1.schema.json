{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/orion/schemas/orion-observation-event.v0_1.schema.json",
  "title": "OrionObservationEvent v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "observed_at",
    "location",
    "severity",
    "confidence",
    "source_record_refs",
    "evidence_grade",
    "policy_state"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0" },
    "event_id": { "type": "string", "pattern": "^orion-evt-[a-z0-9][a-z0-9._-]*$" },
    "event_type": {
      "type": "string",
      "enum": [
        "natural_hazard.fire_weather_alert",
        "natural_hazard.seismic_event",
        "asset.facility",
        "cyber.cve_exposure",
        "field_report.operator_observation",
        "news.public_signal",
        "incident.fused_facility_risk",
        "recon.policy_required",
        "unknown"
      ]
    },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "observed_at": { "type": "string", "format": "date-time" },
    "valid_until": { "type": "string", "format": "date-time" },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "type": "string", "const": "Point" },
        "coordinates": {
          "type": "array",
          "prefixItems": [
            { "type": "number", "minimum": -180, "maximum": 180 },
            { "type": "number", "minimum": -90, "maximum": 90 }
          ],
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_record_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^gaia-src-[a-z0-9][a-z0-9._-]*$" },
      "minItems": 1,
      "uniqueItems": true
    },
    "asset_refs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "related_event_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^orion-evt-[a-z0-9][a-z0-9._-]*$" },
      "uniqueItems": true
    },
    "evidence_grade": {
      "type": "string",
      "enum": [
        "fixture.synthetic",
        "public_source.unverified",
        "public_source.versioned",
        "public_source.attributed",
        "operator_report.unverified",
        "fused.inferred",
        "policy_gated.action"
      ]
    },
    "policy_state": {
      "type": "string",
      "enum": [
        "public_view_allowed",
        "internal_view_allowed",
        "unverified_source",
        "attribution_required",
        "action_gated",
        "scope_required",
        "authorization_required",
        "expired"
      ]
    },
    "policy_envelope_ref": { "type": "string", "pattern": "^orion-pol-[a-z0-9][a-z0-9._-]*$" },
    "decision_card_ref": { "type": "string", "pattern": "^orion-card-[a-z0-9][a-z0-9._-]*$" },
    "receipt_ref": { "type": "string", "pattern": "^orion-rcpt-[a-z0-9][a-z0-9._-]*$" },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
