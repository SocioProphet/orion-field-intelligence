{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ofif://schemas/population-state.v1.json",
  "title": "PopulationState v1",
  "type": "object",
  "required": ["state_id", "as_of_ts", "area_id", "segments", "legitimacy_indicators"],
  "properties": {
    "state_id": { "type": "string" },
    "as_of_ts": { "type": "string", "format": "date-time" },
    "area_id": { "type": "string" },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment_id", "label"],
        "properties": {
          "segment_id": { "type": "string" },
          "label": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "legitimacy_indicators": {
      "type": "array",
      "items": { "$ref": "legitimacy-indicator.v1.json" }
    },
    "fog_of_war": {
      "type": "object",
      "properties": {
        "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "primary_gaps": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
